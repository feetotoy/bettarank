# Copy this file to `.env.local` for local dev, and set the same keys in
# Netlify → Site settings → Environment variables for the deployed site.
# NEVER commit real values — `.env.local` is gitignored.

# ── App ───────────────────────────────────────────────────────────────
# Public base URL of the deployed site (used for absolute links / QR codes).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Supabase (Project Settings → API) ─────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only — full access, bypasses Row Level Security. NEVER expose to the
# browser or prefix with NEXT_PUBLIC. Used only in server code / migrations.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Direct Postgres connection (Project Settings → Database → Connection string).
# Used by Drizzle/Prisma migrations. Use the pooled URL for serverless runtime.
DATABASE_URL=postgresql://postgres:[YOUR-DB-PASSWORD]@db.YOUR-PROJECT-REF.supabase.co:5432/postgres
